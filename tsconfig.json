  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "rootDir": "src",
    "outDir": "public/dist",
    "strict": true,
    "skipLibCheck": true,
    "lib": ["ES2023", "DOM"],
    "types": ["@cloudflare/workers-types"]
  },
  "include": ["src"]
}